# Tesla Fleet API (https://developer.tesla.com)
TESLA_CLIENT_ID=
TESLA_CLIENT_SECRET=
# Region: na (North America / Asia-Pacific) or eu (Europe)
TESLA_REGION=eu
# Must match Tesla developer portal exactly (Origin + Redirect URI)
# TESLA_REDIRECT_URI=http://localhost:8585/callback
# Optional: limit to one vehicle
# TESLA_VIN=

# Optional: leave empty to skip Dropbox and save locally only
# DROPBOX_ACCESS_TOKEN=
#
# App Folder apps can only write inside their app folder (e.g. /invoices).
# Full Dropbox apps can use any path (e.g. /Podjetje/Prejeti).
# DROPBOX_FOLDER=/invoices

# Local folder for downloaded invoice PDFs
INVOICES_DIR=./invoices

# Paths (adjust for Synology)
STATE_FILE=./state.json
LOG_FILE=./tesla-invoicer.log
